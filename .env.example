ANTHROPIC_API_KEY=sk-ant-your-key-here

# RAG — Vector store e embeddings
VOYAGE_API_KEY=pa-your-voyage-key

# Voyage reranker (opzionale)
# Se "true", abilita un secondo passaggio di re-ranking dopo il retrieval semantico
# Migliora rilevanza top-N (+10-15% accuracy attesa) al costo di +50-100ms latency.
# Default: false (no rerank).
VOYAGE_RERANK_ENABLED=false

# Modello rerank Voyage. Default: rerank-2-lite (più veloce, sufficiente).
# Alternative: rerank-2 (più accurato, più lento).
VOYAGE_RERANK_MODEL=rerank-2-lite

# Numero finale di sources nel context + chip UI.
# Default 25 (= comportamento storico).
# Con VOYAGE_RERANK_ENABLED=true conviene 10-15 per stringere ai più rilevanti.
RAG_FINAL_TOP_K=25

# Hybrid retrieval (opzionale)
# Se "true", ogni query è interrogata sia via embedding semantic
# che via BM25 text search (ts_rank Postgres). I due ranking sono
# fusi via RRF interno. Migliora rilevanza su query keyword-specifiche
# (es. "CORS_ORIGIN", nomi file) e su query naturali entrambe.
# Default: false (solo semantic).
RAG_HYBRID_ENABLED=false

SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
# RAG API authentication (for /api/rag/query and /api/rag/ingest)
RAG_API_KEY=sk-rag-generate-your-own-here

# Admin page protection (pagina /admin)
# Genera con: openssl rand -base64 24
ADMIN_PAGE_PASSWORD=change-me-in-env-local

# GitHub webhook secret per re-ingest automatico
# Genera con: openssl rand -hex 32
# Configurato in ognuno dei 13 repo monitorati come webhook secret.
# Se assente, l'endpoint /api/webhooks/github ritorna 500.
GITHUB_WEBHOOK_SECRET=

# Solo per script ops locale scripts/setup-webhooks.sh (creazione hook via API GitHub;
# non usato dal server Next in runtime). Richiede scope admin:repo_hook.
# GITHUB_PAT=