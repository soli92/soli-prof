# Anthropic Claude API
# Genera una chiave su https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# GitHub Packages authentication
# 1. Genera un Personal Access Token su https://github.com/settings/tokens
#    Scopo minimo: read:packages
# 2. Esporta come variabile prima di npm install:
#    export NPM_TOKEN=ghp_...
# 3. Copia questo file a .env.local e aggiungi il valore reale
NPM_TOKEN=ghp_...

# Optional: Vercel deployment
VERCEL_TOKEN=
